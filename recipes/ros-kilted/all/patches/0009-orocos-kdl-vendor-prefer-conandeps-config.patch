--- src/ros2/orocos_kdl_vendor/orocos_kdl_vendor/CMakeLists.txt
+++ src/ros2/orocos_kdl_vendor/orocos_kdl_vendor/CMakeLists.txt
@@ -4,8 +4,21 @@ project(orocos_kdl_vendor)
 find_package(ament_cmake REQUIRED)
 find_package(ament_cmake_vendor_package REQUIRED)
 
 # Set minimum version to find matching what would be built because PyKDL vendor will require it
-find_package(orocos_kdl 1.5.1 QUIET)
+set(_orocos_kdl_conan_hint "")
+foreach(_orocos_kdl_hint IN ITEMS
+    "${CMAKE_CURRENT_SOURCE_DIR}/../../../conan"
+    "${CMAKE_BINARY_DIR}/../../conan")
+  if(IS_DIRECTORY "${_orocos_kdl_hint}")
+    set(_orocos_kdl_conan_hint "${_orocos_kdl_hint}")
+    break()
+  endif()
+endforeach()
+if(_orocos_kdl_conan_hint)
+  find_package(orocos_kdl 1.5.1 QUIET CONFIG PATHS "${_orocos_kdl_conan_hint}" NO_DEFAULT_PATH)
+endif()
+if(NOT orocos_kdl_FOUND)
+  find_package(orocos_kdl 1.5.1 QUIET)
+endif()
 
 if(NOT CMAKE_CXX_STANDARD)
   # orocos_kdl uses some deprecated APIs in C++17, so we set this to C++17
--- src/ros2/orocos_kdl_vendor/orocos_kdl_vendor/orocos_kdl_vendor-extras.cmake
+++ src/ros2/orocos_kdl_vendor/orocos_kdl_vendor/orocos_kdl_vendor-extras.cmake
@@ -12,7 +12,20 @@
 # See the License for the specific language governing permissions and
 # limitations under the License.
 
-find_package(orocos_kdl REQUIRED)
+if(NOT TARGET orocos-kdl AND NOT TARGET orocos_kdl::orocos_kdl)
+  set(_orocos_kdl_conan_hint "")
+  foreach(_orocos_kdl_hint IN ITEMS
+      "${CMAKE_CURRENT_LIST_DIR}/../../../../conan"
+      "${CMAKE_INSTALL_PREFIX}/../conan"
+      "${CMAKE_BINARY_DIR}/../../conan")
+    if(IS_DIRECTORY "${_orocos_kdl_hint}")
+      set(_orocos_kdl_conan_hint "${_orocos_kdl_hint}")
+      break()
+    endif()
+  endforeach()
+  if(_orocos_kdl_conan_hint)
+    find_package(orocos_kdl REQUIRED CONFIG PATHS "${_orocos_kdl_conan_hint}" NO_DEFAULT_PATH)
+  else()
+    find_package(orocos_kdl REQUIRED)
+  endif()
+endif()
 if(NOT TARGET orocos-kdl)
   find_library(orocos_kdl_LIBRARY orocos-kdl REQUIRED)
   add_library(orocos-kdl SHARED IMPORTED)
