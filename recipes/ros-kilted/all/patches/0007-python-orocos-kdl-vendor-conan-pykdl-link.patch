index 0000000..0584956
--- /dev/null
+++ b/src/ros2/orocos_kdl_vendor/python_orocos_kdl_vendor/apply_python_orocos_kdl_patches.cmake
@@ -0,0 +1,20 @@
+# Invoked by FetchContent PATCH_COMMAND as:
+#   cmake -E chdir <SOURCE_DIR> cmake -P .../apply_python_orocos_kdl_patches.cmake
+# so the current working directory is the extracted orocos_kinematics_dynamics tree.
+set(_vendor "${CMAKE_CURRENT_LIST_DIR}")
+set(_patch1 "${_vendor}/patches/0001-use-python3.patch")
+set(_patch2 "${_vendor}/patches/0002-conan-orocos-kdl-pykdl-target.patch")
+
+execute_process(
+  COMMAND git apply -p1 --ignore-space-change --whitespace=nowarn "${_patch1}"
+  RESULT_VARIABLE _r1)
+if(NOT _r1 EQUAL 0)
+  message(FATAL_ERROR "git apply failed (${_r1}): ${_patch1}")
+endif()
+
+execute_process(
+  COMMAND git apply -p1 --ignore-space-change --whitespace=nowarn "${_patch2}"
+  RESULT_VARIABLE _r2)
+if(NOT _r2 EQUAL 0)
+  message(FATAL_ERROR "git apply failed (${_r2}): ${_patch2}")
+endif()
diff --git a/src/ros2/orocos_kdl_vendor/python_orocos_kdl_vendor/patches/0002-conan-orocos-kdl-pykdl-target.patch b/src/ros2/orocos_kdl_vendor/python_orocos_kdl_vendor/patches/0002-conan-orocos-kdl-pykdl-target.patch
new file mode 100644
index 0000000..c188e13
--- /dev/null
+++ b/src/ros2/orocos_kdl_vendor/python_orocos_kdl_vendor/patches/0002-conan-orocos-kdl-pykdl-target.patch
@@ -0,0 +1,44 @@
+diff --git a/python_orocos_kdl/CMakeLists.txt b/python_orocos_kdl/CMakeLists.txt
+index 5727483..59a4913 100644
+--- a/python_orocos_kdl/CMakeLists.txt
++++ b/python_orocos_kdl/CMakeLists.txt
+@@ -27,8 +27,30 @@ project(python_orocos_kdl VERSION 1.5.1)
+ 
+ # find a matching version of orocos_kdl
+ find_package(orocos_kdl ${PROJECT_VERSION} EXACT REQUIRED)
+-include_directories(${orocos_kdl_INCLUDE_DIRS})
+-link_directories(${orocos_kdl_LIBRARY_DIRS})
++# Conan supplies an imported target with transitive usage requirements (Boost, Eigen).
++# Legacy pkg-config-style variables often omit header-only deps, so KDL headers that
++# include boost/shared_ptr.hpp fail on MSVC, macOS, etc.
++if(TARGET orocos_kdl::orocos-kdl)
++  set(_PYKDL_OROCOS_KDL_TARGET orocos_kdl::orocos-kdl)
++elseif(TARGET orocos-kdl::orocos-kdl)
++  set(_PYKDL_OROCOS_KDL_TARGET orocos-kdl::orocos-kdl)
++elseif(TARGET orocos-kdl)
++  set(_PYKDL_OROCOS_KDL_TARGET orocos-kdl)
++else()
++  include_directories(${orocos_kdl_INCLUDE_DIRS})
++  link_directories(${orocos_kdl_LIBRARY_DIRS})
++  set(_PYKDL_OROCOS_KDL_TARGET ${orocos_kdl_LIBRARIES})
++endif()
++
++# Belt-and-suspenders: ensure Boost headers are on the line even if usage requirements
++# do not propagate into this subdirectory (e.g. some pybind11 / FetchContent layouts).
++find_package(Boost QUIET CONFIG)
++set(_PYKDL_BOOST_LIBS "")
++if(TARGET Boost::boost)
++  list(APPEND _PYKDL_BOOST_LIBS Boost::boost)
++elseif(TARGET Boost::headers)
++  list(APPEND _PYKDL_BOOST_LIBS Boost::headers)
++endif()
+ 
+ set(PYBIND11_PYTHON_VERSION 3 CACHE STRING "Python version used by PyBind11")
+ 
+@@ -64,5 +86,5 @@ pybind11_add_module(${LIBRARY_NAME}
+   PyKDL/kinfam.cpp
+   PyKDL/framevel.cpp
+   PyKDL/dynamics.cpp)
+-target_link_libraries(${LIBRARY_NAME} PRIVATE ${orocos_kdl_LIBRARIES})
++target_link_libraries(${LIBRARY_NAME} PRIVATE ${_PYKDL_OROCOS_KDL_TARGET} ${_PYKDL_BOOST_LIBS})
+ install(TARGETS ${LIBRARY_NAME} DESTINATION "${PYTHON_SITE_PACKAGES_INSTALL_DIR}")
