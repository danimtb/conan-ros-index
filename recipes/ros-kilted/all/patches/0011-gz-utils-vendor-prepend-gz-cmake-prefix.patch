--- src/gazebo-release/gz_utils_vendor/CMakeLists.txt
+++ src/gazebo-release/gz_utils_vendor/CMakeLists.txt
@@ -22,6 +22,20 @@ find_package(ament_cmake_export_dependencies REQUIRED)
 
 find_package(gz_cmake_vendor REQUIRED)
 find_package(spdlog_vendor REQUIRED)
+
+# gz_cmake_vendor installs gz-cmake4 under <install>/opt/gz_cmake_vendor, not
+# directly under the ament prefix. Ensure that prefix is present in
+# CMAKE_PREFIX_PATH before ament_vendor() writes the ExternalProject cache so
+# the nested configure can resolve `find_package(gz-cmake4)` on all platforms.
+if(gz_cmake_vendor_DIR)
+  get_filename_component(_gz_cmake_vendor_install_prefix "${gz_cmake_vendor_DIR}/../../.." ABSOLUTE)
+  set(_gz_cmake_vendor_opt_prefix "${_gz_cmake_vendor_install_prefix}/opt/gz_cmake_vendor")
+  if(EXISTS "${_gz_cmake_vendor_opt_prefix}/share/cmake/gz-cmake4/gz-cmake4-config.cmake")
+    list(PREPEND CMAKE_PREFIX_PATH "${_gz_cmake_vendor_opt_prefix}")
+  endif()
+  unset(_gz_cmake_vendor_install_prefix)
+  unset(_gz_cmake_vendor_opt_prefix)
+endif()
 
